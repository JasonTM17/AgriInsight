AGRIINSIGHT_ARTIFACTS=artifacts
AGRIINSIGHT_SEED=20260718
AGRIINSIGHT_AS_OF_DATE=2026-07-18

# Optional XLSX adapter. Leave unset unless the private artifact-tool runtime exists.
# AGRIINSIGHT_NODE_EXECUTABLE=C:\Program Files\nodejs\node.exe
# AGRIINSIGHT_NODE_MODULES=D:\path\to\artifact-tool\node_modules

# Optional PowerShell-session overrides for scripts/run-backend-tests.ps1.
# This file is documentation only; the wrapper does not auto-load .env files.
MAVEN_REPO_LOCAL=D:\AgriInsight\artifacts\_tmp\m2-repository
MAVEN_TEMP_DIR=D:\AgriInsight\artifacts\_tmp\java-tmp
MAVEN_USER_HOME=D:\AgriInsight\artifacts\_tmp\maven-user-home

# Guarded backend runner rejects these hidden Maven channels; keep them empty.
MAVEN_ARGS=
MAVEN_CONFIG=
MAVEN_PROJECTBASEDIR=
