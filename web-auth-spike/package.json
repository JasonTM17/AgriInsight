{
  "name": "@agriinsight/web-auth-spike",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "24.12.0",
    "npm": "11.6.2"
  },
  "scripts": {
    "dev": "next dev --port 3100",
    "build": "next build",
    "start": "next start --port 3100",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-transform-types --test tests/unit/*.test.ts",
    "test:integration": "node --experimental-transform-types --test tests/integration/*.test.ts",
    "test:concurrency": "node --experimental-transform-types --test tests/integration/session-refresh.integration.test.ts",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "next": "16.2.11",
    "openid-client": "6.8.4",
    "pg": "8.22.0",
    "react": "19.2.8",
    "react-dom": "19.2.8"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@types/node": "24.13.3",
    "@types/pg": "8.20.0",
    "@types/react": "19.2.17",
    "typescript": "5.9.3"
  }
}
